#!/bin/bash
#------------------------------------------------------------------------------
# Allclean script for T-junction mixing simulation
# Removes all generated files, keeping the case setup intact
#------------------------------------------------------------------------------
cd "${0%/*}" || exit 1

# Source OpenFOAM run functions
. ${WM_PROJECT_DIR:?}/bin/tools/RunFunctions

echo "Cleaning T-junction mixing case..."

# Remove time directories (except 0)
foamListTimes -rm

# Remove mesh
rm -rf constant/polyMesh/points
rm -rf constant/polyMesh/faces
rm -rf constant/polyMesh/owner
rm -rf constant/polyMesh/neighbour
rm -rf constant/polyMesh/boundary
rm -rf constant/polyMesh/sets
rm -rf constant/polyMesh/cellZones
rm -rf constant/polyMesh/faceZones
rm -rf constant/polyMesh/pointZones

# Remove log files
rm -f log.*

# Remove processor directories (parallel runs)
rm -rf processor*

# Remove postProcessing directory
rm -rf postProcessing

# Remove VTK output
rm -rf VTK

echo "Done."

#------------------------------------------------------------------------------
