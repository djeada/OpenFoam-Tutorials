#!/bin/bash
set -eu

cd "${0%/*}" || exit 1
touch airfoil.foam

ensure_openfoam() {
    if [ -n "${WM_PROJECT_DIR:-}" ]; then
        return
    fi

    for bashrc in \
        /opt/openfoam*/etc/bashrc \
        /usr/lib/openfoam*/etc/bashrc \
        /usr/lib/openfoam/*/etc/bashrc \
        /usr/local/openfoam*/etc/bashrc \
        "$HOME"/OpenFOAM/*/etc/bashrc
    do
        if [ -f "$bashrc" ]; then
            # shellcheck disable=SC1090
            . "$bashrc"
            break
        fi
    done

    : "${WM_PROJECT_DIR:?OpenFOAM not found. Source it first, then rerun ./Allrun.}"
}

ensure_openfoam
. "$WM_PROJECT_DIR"/bin/tools/RunFunctions

MESH_GEO=constant/airfoil_animation.geo
MESH_MSH=constant/airfoil_animation.msh
GENERATOR=../mesh_generation_scripts/generate_naca0012_benchmark_geo.py

echo "========================================"
echo "  NACA 0012 Transient Animation Case"
echo "========================================"

cp 0.orig/U 0/U
cp 0.orig/p 0/p
rm -f 0/Phi 0/phi

if [ -f "$GENERATOR" ]; then
    echo "Step 1: Generating animation-case geometry..."
    python3 "$GENERATOR" \
        --output "$MESH_GEO" \
        --angle-deg -15 \
        --chord-points 121 \
        --domain-xmin -15 \
        --domain-xmax 25 \
        --domain-yhalf 15 \
        --mesh-size-airfoil 0.008 \
        --mesh-size-farfield 0.8 \
        --first-layer 0.002 \
        --bl-thickness 0.05 \
        --bl-ratio 1.12 \
        --near-size 0.018 \
        --near-dist 2.0 \
        --wake-size 0.025 \
        --wake-xmax 15 \
        --wake-yhalf 4 \
        --split-farfield
else
    echo "Step 1: Reusing existing $MESH_GEO..."
fi

if [ ! -f "$MESH_MSH" ]; then
    if command -v gmsh >/dev/null 2>&1; then
        echo "Step 2: Meshing with Gmsh..."
        gmsh -3 -format msh2 "$MESH_GEO" -o "$MESH_MSH"
    else
        echo "Missing $MESH_MSH and gmsh is not available."
        echo "Generate the mesh on the host first, or use ./run_docker.sh."
        exit 1
    fi
else
    echo "Step 2: Reusing existing $MESH_MSH..."
fi

echo "Step 3: Importing Gmsh mesh into OpenFOAM..."
runApplication gmshToFoam "$MESH_MSH"

echo "Step 4: Setting patch types..."
runApplication changeDictionary

echo "Step 5: Renumbering mesh..."
runApplication renumberMesh -overwrite

echo "Step 6: Checking mesh quality..."
runApplication checkMesh

echo "Step 7: Running pimpleFoam..."
runApplication pimpleFoam

echo "========================================"
echo "  Transient animation case complete"
echo "========================================"
