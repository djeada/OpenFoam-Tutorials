// Domain sizing rationale:
//   Boat length L ≈ 0.155 m, width W ≈ 0.082 m, height H ≈ 0.054 m
//   Upstream:   ~3L = 0.5 m    →  xMin = -0.5
//   Downstream: ~6L = 1.0 m    →  xMax =  1.0
//   Lateral:    ~3W each side   →  yMin = -0.25, yMax = 0.25
//   Below:      ~3H             →  zMin = -0.15
//   Above:      ~3H             →  zMax =  0.15
//   Water level at z = 0

vertices
(
    (-0.5  -0.25  -0.15)   // 0
    ( 1.0  -0.25  -0.15)   // 1
    ( 1.0   0.25  -0.15)   // 2
    (-0.5   0.25  -0.15)   // 3
    (-0.5  -0.25   0.15)   // 4
    ( 1.0  -0.25   0.15)   // 5
    ( 1.0   0.25   0.15)   // 6
    (-0.5   0.25   0.15)   // 7
);

blocks
(
