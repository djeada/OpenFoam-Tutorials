#!/bin/bash
#------------------------------------------------------------------------------
# Allclean script for heated pipe flow
# Removes all generated files, restoring the case to its initial state
#------------------------------------------------------------------------------
cd "${0%/*}" || exit

# Source OpenFOAM run functions
. ${WM_PROJECT_DIR:?}/bin/tools/CleanFunctions

echo "============================================"
echo "  Cleaning heated pipe flow case..."
echo "============================================"

# Clean all time directories (except 0/)
cleanCase

# Remove log files
rm -f log.*

# Remove processor directories (if decomposed)
rm -rf processor*

# Remove postProcessing directory
rm -rf postProcessing

echo "  Done. Case restored to initial state."
echo "============================================"
