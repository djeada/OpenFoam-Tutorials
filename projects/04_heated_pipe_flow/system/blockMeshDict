FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1;

// Domain: 2m long (x) x 0.1m tall (y) x 0.01m deep (z)
// Approximates a 2D heated rectangular duct

vertices
(
    (0    0     0)       // 0
    (2    0     0)       // 1
    (2    0.1   0)       // 2
    (0    0.1   0)       // 3
    (0    0     0.01)    // 4
    (2    0     0.01)    // 5
    (2    0.1   0.01)    // 6
    (0    0.1   0.01)    // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (100 20 1) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 4 7 3)
        );
    }

    outlet
    {
        type patch;
        faces
        (
            (1 2 6 5)
        );
    }

    topWall
    {
        type wall;
        faces
        (
            (3 7 6 2)
        );
    }

    bottomWall
    {
        type wall;
        faces
        (
            (0 1 5 4)
        );
    }

    frontAndBack
    {
        type empty;
        faces
        (
            (0 3 2 1)
            (4 5 6 7)
        );
    }
);

mergePatchPairs
(
);

