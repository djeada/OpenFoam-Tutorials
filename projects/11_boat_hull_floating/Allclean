#!/bin/bash
# ============================================================================
# Allclean — remove generated files for floating boat hull case
# ============================================================================
cd "${0%/*}" || exit
. "${WM_PROJECT_DIR:?}"/bin/tools/CleanFunctions

cleanCase

# Remove STL copy in triSurface (generated by Allrun)
rm -f constant/triSurface/boat_hull.stl

# Remove additional dynamic-mesh artefacts
rm -rf constant/extendedFeatureEdgeMesh
rm -f  constant/triSurface/boat_hull.eMesh
rm -rf processor*
rm -rf postProcessing

echo "Case cleaned."
