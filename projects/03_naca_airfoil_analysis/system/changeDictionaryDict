FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      changeDictionaryDict;
}

boundary
{
    inlet
    {
        type patch;
    }

    outlet
    {
        type patch;
    }

    top
    {
        type symmetryPlane;
    }

    bottom
    {
        type symmetryPlane;
    }

    airfoil
    {
        type wall;
    }

    frontAndBack
    {
        type empty;
    }
}

