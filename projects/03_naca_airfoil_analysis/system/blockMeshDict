FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1;

vertices
(
    (-0.5 -0.5 -0.1)  // 0
    (2.0 -0.5 -0.1)   // 1, extend x-coordinate for right extension
    (2.0  0.5 -0.1)   // 2, extend x-coordinate for right extension
    (-0.5  0.5 -0.1)  // 3
    (-0.5 -0.5  0.1)  // 4
    (2.0 -0.5  0.1)   // 5, extend x-coordinate for right extension
    (2.0  0.5  0.1)   // 6, extend x-coordinate for right extension
    (-0.5  0.5  0.1)  // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (60 20 1) simpleGrading (1 1 1)
    // Increase the number of cells in the x-direction to maintain mesh resolution
);

edges
(
);

boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 4 7 3)
        );
    }
    outlet
    {
        type patch;
        faces
        (
            (1 5 6 2)
        );
    }
    walls
    {
        type wall;
        faces
        (
            (3 2 6 7)
            (0 1 5 4)
        );
    }
    frontAndBack
    {
        type empty;
        faces
        (
            (0 3 2 1)
            (4 7 6 5)
        );
    }
);

mergePatchPairs
(
);

